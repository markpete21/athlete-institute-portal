# Athlete Institute Portal — environment variables
# Wired in by Module 0 stage: (2) Clerk, (4) Stripe, (5) Supabase/brands,
# (6) Resend/Twilio/web-push, (7) storage. Nothing is required for Stage 1.

# ── Clerk (Stage 2) ─────────────────────────────────────────────────────────
# SHARED production instance clerk.athleteinstitute.ca — same keys family as
# the live/tickets apps, so sign-in is shared across every AI app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ── Supabase (Stage 5+) ─────────────────────────────────────────────────────
# The portal's OWN Supabase project (deliberate deviation from the spec's
# shared-DB assumption — see README "Architecture decisions").
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (Stage 4) ────────────────────────────────────────────────────────
# Canadian account; cards + PAD (acss_debit). Same account as live/tickets.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Resend email (Stage 6) ──────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=

# ── Twilio SMS (Stage 6) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Web push (Stage 6) ──────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── App ─────────────────────────────────────────────────────────────────────
# Optional overrides; production defaults are the real subdomains.
NEXT_PUBLIC_PLAY_URL=
NEXT_PUBLIC_ADMIN_URL=
